<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.vueboard.domains.kanban.mapper.KanbanBoardMapper">
	<!-- boardId 조회: TB_KANBAN_BOARD.BOARD_ID(VARCHAR2) by PN(NUMBER) -->
	<select id="getBoardIdByPn" parameterType="long" resultType="string">
		SELECT BOARD_ID
		FROM TB_KANBAN_BOARD
		WHERE PN = #{pn}
	</select>
</mapper>